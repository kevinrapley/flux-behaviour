{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flux-behaviour.pages.dev/contracts/models/flux-service-model.schema.json",
  "title": "Flux publisher service model",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "tenant_id", "model_key", "version", "entities", "bindings", "outcomes", "key_events"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "tenant_id": { "$ref": "#/$defs/key" },
    "model_key": { "$ref": "#/$defs/key" },
    "version": { "type": "integer", "minimum": 1 },
    "entities": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "type", "label", "position"],
        "properties": {
          "key": { "$ref": "#/$defs/key" },
          "type": { "type": "string", "enum": ["service", "transaction", "task", "step", "question", "field"] },
          "label": { "type": "string", "minLength": 1, "maxLength": 120, "pattern": "^(?!.*https?:)[^@\\r\\n]+$" },
          "parent_key": { "$ref": "#/$defs/key" },
          "position": { "type": "integer", "minimum": 1, "maximum": 10000 },
          "complexity": { "$ref": "#/$defs/complexity" },
          "required": { "type": "boolean" }
        },
        "allOf": [
          {
            "if": { "properties": { "type": { "const": "question" } }, "required": ["type"] },
            "then": { "required": ["complexity"] },
            "else": { "not": { "required": ["complexity"] } }
          },
          {
            "if": { "properties": { "type": { "const": "field" } }, "required": ["type"] },
            "then": { "required": ["required"] },
            "else": { "not": { "required": ["required"] } }
          }
        ]
      }
    },
    "bindings": {
      "type": "array",
      "maxItems": 10000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["element_key", "entity_key"],
        "properties": {
          "element_key": { "type": "string", "minLength": 3, "maxLength": 160, "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$" },
          "entity_key": { "$ref": "#/$defs/key" }
        }
      }
    },
    "outcomes": {
      "type": "array",
      "maxItems": 1000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "label", "transaction_key", "type"],
        "properties": {
          "key": { "$ref": "#/$defs/key" },
          "label": { "$ref": "#/$defs/label" },
          "transaction_key": { "$ref": "#/$defs/key" },
          "type": { "type": "string", "enum": ["success", "failure", "progress", "abandonment"] }
        }
      }
    },
    "key_events": {
      "type": "array",
      "maxItems": 2000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "label", "action", "element_key", "outcome_key"],
        "properties": {
          "key": { "$ref": "#/$defs/key" },
          "label": { "$ref": "#/$defs/label" },
          "action": { "$ref": "#/$defs/key" },
          "element_key": { "$ref": "#/$defs/element_key" },
          "outcome_key": { "$ref": "#/$defs/key" }
        }
      }
    }
  },
  "$defs": {
    "key": { "type": "string", "minLength": 3, "maxLength": 120, "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$" },
    "label": { "type": "string", "minLength": 1, "maxLength": 120, "pattern": "^(?!.*https?:)[^@\\r\\n]+$" },
    "element_key": { "type": "string", "minLength": 3, "maxLength": 160, "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$" },
    "complexity": { "type": "integer", "minimum": 1, "maximum": 7 }
  }
}
