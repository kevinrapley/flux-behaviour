<!doctype html>
<html class="govuk-template govuk-template--rebranded" lang="en">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>{{ pageTitle }} – Flux Behaviour demo</title>
	<link rel="stylesheet" href="/assets/styles/demo.css" media="all">
	{% block head %}{% endblock %}
</head>
<body class="govuk-template__body">
	<script>document.body.className += ' js-enabled' + ('noModule' in HTMLScriptElement.prototype ? ' govuk-frontend-supported' : '');</script>
	<a href="#main-content" class="govuk-skip-link" data-module="govuk-skip-link">Skip to main content</a>
	{% block consentBanner %}{% endblock %}
	<header class="govuk-header" data-module="govuk-header">
		<div class="govuk-header__container govuk-width-container">
			<div class="govuk-header__logo">
				<a href="/" class="govuk-header__link govuk-header__link--homepage">
					<span class="govuk-header__logotype-text">Flux Behaviour</span>
				</a>
			</div>
		</div>
	</header>
	<div class="govuk-service-navigation" data-module="govuk-service-navigation">
		<div class="govuk-width-container">
			<div class="govuk-service-navigation__container">
				<span class="govuk-service-navigation__service-name">
					<a href="/" class="govuk-service-navigation__link">Behavioural analytics demo</a>
				</span>
				<nav aria-label="Menu" class="govuk-service-navigation__wrapper">
					<ul class="govuk-service-navigation__list">
						<li class="govuk-service-navigation__item{% if activeNavigation == 'home' %} govuk-service-navigation__item--active{% endif %}">
							<a class="govuk-service-navigation__link" href="/"{% if activeNavigation == 'home' %} aria-current="true"{% endif %}>Get started</a>
						</li>
						<li class="govuk-service-navigation__item{% if activeNavigation == 'developers' %} govuk-service-navigation__item--active{% endif %}">
							<a class="govuk-service-navigation__link" href="/developers/"{% if activeNavigation == 'developers' %} aria-current="true"{% endif %}>Developers</a>
						</li>
						<li class="govuk-service-navigation__item{% if activeNavigation == 'journey' %} govuk-service-navigation__item--active{% endif %}">
							<a class="govuk-service-navigation__link" href="/journey/"{% if activeNavigation == 'journey' %} aria-current="true"{% endif %}>Demo journey</a>
						</li>
						<li class="govuk-service-navigation__item{% if activeNavigation == 'playground' %} govuk-service-navigation__item--active{% endif %}">
							<a class="govuk-service-navigation__link" href="/playground/"{% if activeNavigation == 'playground' %} aria-current="true"{% endif %}>Playground</a>
						</li>
						<li class="govuk-service-navigation__item{% if activeNavigation == 'dashboard' %} govuk-service-navigation__item--active{% endif %}">
							<a class="govuk-service-navigation__link" href="/dashboard/"{% if activeNavigation == 'dashboard' %} aria-current="true"{% endif %}>Dashboard</a>
						</li>
						<li class="govuk-service-navigation__item{% if activeNavigation == 'admin' %} govuk-service-navigation__item--active{% endif %}">
							<a class="govuk-service-navigation__link" href="/admin/"{% if activeNavigation == 'admin' %} aria-current="true"{% endif %}>Admin</a>
						</li>
						<li class="govuk-service-navigation__item{% if activeNavigation == 'account' %} govuk-service-navigation__item--active{% endif %}">
							<a class="govuk-service-navigation__link" href="/account/"{% if activeNavigation == 'account' %} aria-current="true"{% endif %}>Sign in</a>
						</li>
					</ul>
				</nav>
			</div>
		</div>
	</div>
	<div class="govuk-width-container">
		<main class="govuk-main-wrapper" id="main-content" role="main">
			{% block content %}{% endblock %}
		</main>
	</div>
	<footer class="govuk-footer">
		<div class="govuk-width-container">
			<div class="govuk-footer__meta">
				<div class="govuk-footer__meta-item govuk-footer__meta-item--grow">
					<h2 class="govuk-visually-hidden">Support links</h2>
					<ul class="govuk-footer__inline-list">
						<li class="govuk-footer__inline-list-item">
							<a class="govuk-footer__link" href="https://github.com/kevinrapley/flux-behaviour">Source repository</a>
						</li>
						<li class="govuk-footer__inline-list-item">
							<a class="govuk-footer__link" href="https://github.com/ONSdigital/Charts">ONS Charts</a>
						</li>
					</ul>
					<span class="govuk-footer__licence-description">
						{% if activeNavigation == 'account' %}Dashboard account identity is stored separately from analytics identifiers. Behavioural events are consented, metadata-only and follow the Flux event contract.{% elif activeNavigation == 'admin' %}Account email addresses are used only to manage Flux administration access and are stored separately from analytics identifiers. Behavioural events remain consented and metadata-only.{% else %}Demo prototype. No real user data is collected. Events are consented, metadata-only and follow the Flux event contract.{% endif %}
					</span>
				</div>
			</div>
		</div>
	</footer>
	<script type="module" src="/assets/govuk/govuk-frontend.min.js"></script>
	<script type="module">
		import { initAll } from '/assets/govuk/govuk-frontend.min.js';
		initAll();
	</script>
	{% block scripts %}{% endblock %}
</body>
</html>
