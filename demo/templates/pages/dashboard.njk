{% extends "layout.njk" %}

{% block content %}
<div class="govuk-grid-row">
	<div class="govuk-grid-column-two-thirds">
		<span class="govuk-caption-xl">Dashboard</span>
		<h1 class="govuk-heading-xl">Behavioural signals</h1>
		<p class="govuk-body">This dashboard presents consented, pseudonymous ResearchOps interaction analytics. It is evidence about service friction, never a judgement of an individual.</p>
	</div>
</div>

<div class="govuk-grid-row">
	<div class="govuk-grid-column-full">
		<h2 class="govuk-heading-l">Live ResearchOps journeys</h2>
		<p class="govuk-body" data-flux-live-status aria-live="polite">Loading live analytics…</p>
		<table class="govuk-table">
			<thead class="govuk-table__head"><tr class="govuk-table__row"><th class="govuk-table__header">Visitor</th><th class="govuk-table__header">Visitor type</th><th class="govuk-table__header">Session started</th></tr></thead>
			<tbody class="govuk-table__body" data-flux-live-sessions></tbody>
		</table>
		<h3 class="govuk-heading-m">Session journey narrative</h3>
		<div data-flux-live-journeys></div>
		<div data-flux-live-analytics></div>
	</div>
</div>
{% endblock %}

{% block scripts %}
<script type="module" src="/assets/flux/dashboard/live-dashboard.mjs"></script>
{% endblock %}
