{% extends "layout.njk" %}

{% block content %}
<div class="flux-dashboard" data-flux-dashboard data-flux-tenant="researchops" aria-busy="true">
	<header class="flux-dashboard__header">
		<div>
			<span class="govuk-caption-l">ResearchOps</span>
			<h1 class="govuk-heading-xl flux-dashboard__title">Behavioural analytics</h1>
			<p class="govuk-body-l flux-dashboard__lede">See how people move through the service, where journeys slow down, and whether visitors come back.</p>
		</div>
		<div class="flux-dashboard__controls" aria-label="Dashboard period">
			<div class="flux-dashboard__range" role="group" aria-label="Choose reporting period">
				<button type="button" class="flux-dashboard__range-button" data-flux-range="24h">24 hours</button>
				<button type="button" class="flux-dashboard__range-button" data-flux-range="7d">7 days</button>
				<button type="button" class="flux-dashboard__range-button flux-dashboard__range-button--active" data-flux-range="30d" aria-pressed="true">30 days</button>
				<button type="button" class="flux-dashboard__range-button" data-flux-range="90d">90 days</button>
				<button type="button" class="flux-dashboard__range-button" data-flux-range="1y">1 year</button>
				<button type="button" class="flux-dashboard__range-button" data-flux-range="all">All time</button>
				<button type="button" class="flux-dashboard__range-button" data-flux-range="custom">Custom</button>
			</div>
			<div class="flux-dashboard__custom-range" data-flux-custom-range hidden>
				<label for="flux-custom-start">From <input class="govuk-input govuk-input--width-10" id="flux-custom-start" type="date" data-flux-custom-start></label>
				<label for="flux-custom-end">To <input class="govuk-input govuk-input--width-10" id="flux-custom-end" type="date" data-flux-custom-end></label>
				<button type="button" class="govuk-button govuk-button--secondary" data-flux-custom-apply>Apply dates</button>
			</div>
			<label class="flux-dashboard__compare" for="flux-dashboard-compare">Compare by
				<select class="govuk-select" id="flux-dashboard-compare" data-flux-compare>
					<option value="period">Previous period</option>
					<option value="visit_maturity">Visit maturity</option>
					<option value="outcome">Outcome path</option>
					<option value="task">Configured task</option>
					<option value="interaction_mode">Interaction mode</option>
				</select>
			</label>
			<div class="flux-dashboard__export">
				<label for="flux-dashboard-export-report">Export aggregate report
					<select class="govuk-select" id="flux-dashboard-export-report" data-flux-export-report>
						<option value="overview">Overview</option>
						<option value="events">Events</option>
						<option value="key_events">Key events</option>
						<option value="elements">Pages, forms and controls</option>
						<option value="entities">Service entities</option>
						<option value="funnels">Funnels</option>
						<option value="fields">Fields</option>
						<option value="comparison">Selected comparison</option>
					</select>
				</label>
				<a class="govuk-button govuk-button--secondary" data-flux-export href="/api/dashboard/researchops/export.csv?report=overview&amp;range=30d">Download CSV</a>
				<p class="govuk-body-s">Includes filters, generated time, model and event-schema version, caveats and suppression notes. Never raw events.</p>
			</div>
			<button type="button" class="flux-dashboard__refresh" data-flux-refresh>Refresh data</button>
		</div>
	</header>

	<p class="flux-dashboard__status" data-flux-live-status aria-live="polite">Loading ResearchOps analytics…</p>

	<div data-flux-dashboard-content hidden>
		<nav class="flux-report-navigation" aria-label="Analytics reports" data-flux-report-navigation>
			<ul class="flux-report-navigation__list">
				<li><a href="?view=overview" data-flux-view="overview" aria-current="page">Overview</a></li>
				<li><a href="?view=realtime" data-flux-view="realtime">Realtime</a></li>
				<li><a href="?view=journeys" data-flux-view="journeys">Journeys</a></li>
				<li><a href="?view=tasks" data-flux-view="tasks">Tasks and funnels</a></li>
				<li><a href="?view=fields" data-flux-view="fields">Fields</a></li>
				<li><a href="?view=events" data-flux-view="events">Events</a></li>
				<li><a href="?view=cohorts" data-flux-view="cohorts">Cohorts</a></li>
				<li><a href="?view=model" data-flux-view="model">Model and explainability</a></li>
				<li><a href="?view=governance" data-flux-view="governance">Data quality and governance</a></li>
			</ul>
		</nav>

		<section class="flux-dashboard__panel flux-dashboard__panel--realtime" aria-labelledby="realtime-heading" data-flux-report-area="realtime" hidden>
			<div class="flux-dashboard__section-heading">
				<div>
					<h2 class="govuk-heading-l" id="realtime-heading">Realtime activity</h2>
					<p class="govuk-body flux-dashboard__section-copy">See accepted interactions and active sessions from the last 5 and 30 minutes, with collection freshness.</p>
				</div>
			</div>
			<div data-flux-realtime></div>
		</section>

		<section aria-labelledby="overview-heading" data-flux-report-area="overview">
			<div class="flux-dashboard__section-heading">
				<div>
					<h2 class="govuk-heading-l" id="overview-heading">Audience overview</h2>
					<p class="govuk-body flux-dashboard__section-copy" data-flux-period-copy></p>
				</div>
			</div>
			<div class="flux-metric-grid" data-flux-overview></div>
			<div data-flux-uncertainty></div>
		</section>

		<section class="flux-dashboard__panel" aria-labelledby="comparison-report-heading" data-flux-report-area="overview">
			<div class="flux-dashboard__section-heading">
				<div>
					<h2 class="govuk-heading-l" id="comparison-report-heading">Journey comparison</h2>
					<p class="govuk-body flux-dashboard__section-copy">Compare aggregate service evidence by a safe journey dimension. Small groups are suppressed.</p>
				</div>
			</div>
			<div data-flux-comparison-report></div>
		</section>

		<section class="flux-dashboard__panel flux-dashboard__panel--trend" aria-labelledby="trend-heading" data-flux-report-area="overview">
			<div class="flux-dashboard__section-heading">
				<div>
					<h2 class="govuk-heading-l" id="trend-heading">Audience activity</h2>
					<p class="govuk-body flux-dashboard__section-copy">Daily visitors and sessions show whether engagement is building over time.</p>
				</div>
				<div class="flux-chart-legend" aria-hidden="true"><span><i class="flux-chart-legend__key flux-chart-legend__key--visitors"></i>Visitors</span><span><i class="flux-chart-legend__key flux-chart-legend__key--sessions"></i>Sessions</span></div>
			</div>
			<div data-flux-trend></div>
		</section>

		<section class="flux-dashboard__panel" aria-labelledby="service-model-heading" data-flux-report-area="model" hidden>
			<div class="flux-dashboard__section-heading">
				<div>
					<h2 class="govuk-heading-l" id="service-model-heading">Service model and data quality</h2>
					<p class="govuk-body flux-dashboard__section-copy">Check which service structure is published, its declared complexity and how much of the selected-period interaction stream maps to it.</p>
				</div>
			</div>
			<div data-flux-service-model></div>
		</section>

		<section class="flux-dashboard__panel" aria-labelledby="event-report-heading" data-flux-report-area="events" hidden>
			<div class="flux-dashboard__section-heading">
				<div>
					<h2 class="govuk-heading-l" id="event-report-heading">Events and key events</h2>
					<p class="govuk-body flux-dashboard__section-copy">Explore interaction volume, journey reach, configured outcomes and change from the previous comparable period.</p>
				</div>
			</div>
			<div data-flux-event-report></div>
		</section>

		<section class="flux-dashboard__panel" aria-labelledby="entity-report-heading" data-flux-report-area="tasks" hidden>
			<div class="flux-dashboard__section-heading">
				<div>
					<h2 class="govuk-heading-l" id="entity-report-heading">Service performance</h2>
					<p class="govuk-body flux-dashboard__section-copy">Compare journeys through configured transactions, tasks, steps, questions and fields, including entry, exit, outcomes, friction and time.</p>
				</div>
			</div>
			<div data-flux-entity-report></div>
		</section>

		<section class="flux-dashboard__panel flux-model-manager" aria-labelledby="task-funnel-manager-heading" data-flux-report-area="tasks" hidden>
			<div class="flux-dashboard__section-heading">
				<div>
					<h2 class="govuk-heading-l" id="task-funnel-manager-heading">Configure tasks and funnels</h2>
					<p class="govuk-body flux-dashboard__section-copy">Create the service journeys Flux should measure. Each saved change publishes a new model version, preserving the meaning of historical analytics.</p>
				</div>
			</div>
			<details class="govuk-details flux-model-manager__disclosure">
				<summary class="govuk-details__summary">
					<span class="govuk-details__summary-text">Manage published configuration</span>
				</summary>
				<div class="govuk-details__text">
					<div data-flux-task-funnel-manager aria-live="polite"></div>
				</div>
			</details>
		</section>

		<section class="flux-dashboard__panel" aria-labelledby="funnel-report-heading" data-flux-report-area="tasks" hidden>
			<div class="flux-dashboard__section-heading">
				<div>
					<h2 class="govuk-heading-l" id="funnel-report-heading">Tasks and funnels</h2>
					<p class="govuk-body flux-dashboard__section-copy">Follow configured transactions from their first interaction through ordered steps, outcomes, abandonment and recovery.</p>
				</div>
			</div>
			<div data-flux-funnel-report></div>
		</section>

		<section class="flux-dashboard__panel" aria-labelledby="field-report-heading" data-flux-report-area="fields" hidden>
			<div class="flux-dashboard__section-heading">
				<div>
					<h2 class="govuk-heading-l" id="field-report-heading">Fields</h2>
					<p class="govuk-body flux-dashboard__section-copy">Understand field exposure, interaction, validation, correction, dwell and safe value-length distributions without collecting entered values.</p>
				</div>
			</div>
			<div data-flux-field-report></div>
		</section>

		<div class="flux-dashboard__split" data-flux-report-area="overview">
			<section class="flux-dashboard__panel" aria-labelledby="health-heading">
				<h2 class="govuk-heading-l" id="health-heading">Journey health</h2>
				<p class="govuk-body flux-dashboard__section-copy">Signals that reveal effort, recovery and completion across the selected period.</p>
				<div data-flux-health></div>
			</section>
			<section class="flux-dashboard__panel" aria-labelledby="interactions-heading">
				<h2 class="govuk-heading-l" id="interactions-heading">Top interactions</h2>
				<p class="govuk-body flux-dashboard__section-copy">The behaviours people use most often while navigating ResearchOps.</p>
				<div data-flux-interactions></div>
			</section>
		</div>

		<section class="flux-dashboard__panel flux-dashboard__panel--cohorts" aria-labelledby="cohorts-heading" data-flux-report-area="cohorts" hidden>
			<div class="flux-dashboard__section-heading">
				<div>
					<h2 class="govuk-heading-l" id="cohorts-heading">Journey cohorts</h2>
					<p class="govuk-body flux-dashboard__section-copy">Compare groups of journeys by visit maturity, outcome and supported interaction patterns without identifying a visitor.</p>
				</div>
			</div>
			<div data-flux-cohorts></div>
		</section>

		<section class="flux-dashboard__panel" aria-labelledby="signals-heading" data-flux-report-area="model" hidden>
			<div class="flux-dashboard__section-heading">
				<div>
					<h2 class="govuk-heading-l" id="signals-heading">Behavioural signals</h2>
					<p class="govuk-body flux-dashboard__section-copy">Median service-friction indicators across recent sessions in this period.</p>
				</div>
			</div>
			<div data-flux-signals></div>
		</section>

		<section aria-labelledby="journeys-heading" data-flux-report-area="journeys" hidden>
			<div class="flux-dashboard__section-heading">
				<div>
					<h2 class="govuk-heading-l" id="journeys-heading">Recent journeys</h2>
					<p class="govuk-body flux-dashboard__section-copy">Open a journey to understand its sequence of consented interactions. Visitor identities remain pseudonymous.</p>
				</div>
			</div>
			<div class="flux-journey-list" data-flux-live-journeys></div>
		</section>

		<section class="flux-dashboard__panel" aria-labelledby="governance-heading" data-flux-report-area="governance" hidden>
			<div class="flux-dashboard__section-heading">
				<div>
					<h2 class="govuk-heading-l" id="governance-heading">Data quality and governance</h2>
					<p class="govuk-body flux-dashboard__section-copy">Review freshness, semantic coverage, schema and model versions, export boundaries and controls that are not yet evidenced.</p>
				</div>
			</div>
			<div data-flux-governance></div>
		</section>
	</div>
</div>
{% endblock %}

{% block scripts %}
<script type="module" src="/assets/flux/dashboard/live-dashboard.mjs"></script>
{% endblock %}
