{% extends "layout.njk" %}

{% block consentBanner %}
<div class="govuk-cookie-banner" data-nosnippet role="region" aria-label="Consent to behavioural analytics" id="flux-consent-banner">
	<div class="govuk-cookie-banner__message govuk-width-container">
		<div class="govuk-grid-row">
			<div class="govuk-grid-column-two-thirds">
				<h2 class="govuk-cookie-banner__heading govuk-heading-m">Behavioural analytics on this demo</h2>
				<div class="govuk-cookie-banner__content">
					<p class="govuk-body">With your consent, this demo measures interaction metadata such as how long fields take and where errors happen. It never records what you type.</p>
				</div>
			</div>
		</div>
		<div class="govuk-button-group">
			<button value="accept" type="button" name="flux-consent" class="govuk-button" data-module="govuk-button" id="flux-consent-accept">Accept behavioural analytics</button>
			<button value="reject" type="button" name="flux-consent" class="govuk-button" data-module="govuk-button" id="flux-consent-reject">Reject behavioural analytics</button>
		</div>
	</div>
</div>
{% endblock %}

{% block content %}
<div class="govuk-grid-row">
	<div class="govuk-grid-column-two-thirds">
		<span class="govuk-caption-xl">Demo journey</span>
		<h1 class="govuk-heading-xl">Apply for a demo licence</h1>
		<p class="govuk-body">This form is instrumented with the Flux tag. If you accept behavioural analytics, interacting with the fields below emits consented, metadata-only events. The panel underneath shows exactly what leaves the page.</p>

		<form id="demo-journey-form" novalidate>
			<div class="govuk-form-group">
				<label class="govuk-label govuk-label--m" for="full-name">Full name</label>
				<div id="full-name-hint" class="govuk-hint">Only the length of what you type is measured, never the content.</div>
				<input class="govuk-input" id="full-name" name="full-name" type="text" aria-describedby="full-name-hint" data-flux-field="full-name">
			</div>

			<div class="govuk-form-group">
				<label class="govuk-label govuk-label--m" for="licence-reason">Why do you need a licence?</label>
				<textarea class="govuk-textarea" id="licence-reason" name="licence-reason" rows="4" data-flux-field="licence-reason"></textarea>
			</div>

			<div class="govuk-form-group">
				<fieldset class="govuk-fieldset">
					<legend class="govuk-fieldset__legend govuk-fieldset__legend--m">How would you like to be contacted?</legend>
					<div class="govuk-radios" data-module="govuk-radios">
						<div class="govuk-radios__item">
							<input class="govuk-radios__input" id="contact-email" name="contact" type="radio" value="email" data-flux-field="contact">
							<label class="govuk-label govuk-radios__label" for="contact-email">Email</label>
						</div>
						<div class="govuk-radios__item">
							<input class="govuk-radios__input" id="contact-phone" name="contact" type="radio" value="phone" data-flux-field="contact">
							<label class="govuk-label govuk-radios__label" for="contact-phone">Phone</label>
						</div>
					</div>
				</fieldset>
			</div>

			<details class="govuk-details" id="journey-help" data-flux-help="licence-help">
				<summary class="govuk-details__summary">
					<span class="govuk-details__summary-text">Help with this application</span>
				</summary>
				<div class="govuk-details__text">Opening this help section emits an assist event so services can see which questions need better guidance.</div>
			</details>

			<button type="submit" class="govuk-button" data-module="govuk-button">Continue</button>
		</form>
	</div>
</div>

<div class="govuk-grid-row">
	<div class="govuk-grid-column-full">
		<h2 class="govuk-heading-l">Events emitted by this page</h2>
		<p class="govuk-body" id="flux-event-log-status">No consent decision yet. Events are dropped until you accept behavioural analytics.</p>
		<table class="govuk-table" id="flux-event-log" aria-live="polite">
			<caption class="govuk-table__caption govuk-visually-hidden">Log of behavioural events emitted by this page</caption>
			<thead class="govuk-table__head">
				<tr class="govuk-table__row">
					<th scope="col" class="govuk-table__header">Class</th>
					<th scope="col" class="govuk-table__header">Action</th>
					<th scope="col" class="govuk-table__header">Element</th>
					<th scope="col" class="govuk-table__header">Metadata</th>
					<th scope="col" class="govuk-table__header">Status</th>
				</tr>
			</thead>
			<tbody class="govuk-table__body" id="flux-event-log-body"></tbody>
		</table>
	</div>
</div>
{% endblock %}

{% block scripts %}
<script type="module" src="/assets/demo/demo-journey.js" data-flux-endpoint="{{ collectorEndpoint }}"></script>
{% endblock %}
