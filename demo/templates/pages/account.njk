{% extends "layout.njk" %}

{% block content %}
	<div class="govuk-grid-row">
		<div class="govuk-grid-column-two-thirds">
			<h1 class="govuk-heading-xl">Sign in to Flux Behaviour</h1>
			<p class="govuk-body">Use the Google account that your Flux workspace administrator has granted access to. Flux does not collect your Google password or use email one-time codes.</p>
			<a class="govuk-button" href="/api/auth/google/start">Continue with Google</a>
			<p class="govuk-body">If you cannot access the dashboard after signing in, ask the workspace administrator to add your Google email address.</p>
		</div>
	</div>
{% endblock %}
